{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AI Scene Schema",
  "type": "object",
  "required": ["scene_name","description","intent","target_room","actions","confidence","entity_map"],
  "additionalProperties": false,
  "properties": {
    "scene_name": {"type": "string"},
    "description": {"type": "string"},
    "intent": {"type": "string"},
    "target_room": {"type": "string"},
    "confidence": {"type": "number","minimum":0,"maximum":1},
    "warnings": {"type":"array","items":{"type":"string"}},
    "assumptions": {"type":"array","items":{"type":"string"}},
    "entity_map": {"type":"object","additionalProperties":{
      "type":"object",
      "properties":{
        "entity_id":{"type":"string"},
        "domain":{"type":"string"},
        "capabilities":{"type":"array","items":{"type":"string"}}
      },
      "required":["entity_id","domain","capabilities"]
    }},
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["entity_id","domain","service","data"],
        "additionalProperties": false,
        "properties": {
          "entity_id": {"type": "string"},
          "domain": {"type": "string"},
          "service": {"type": "string"},
          "data": {"type": "object"},
          "rationale": {"type": "string"},
          "priority": {"type": "integer"}
        }
      }
    }
  }
}
